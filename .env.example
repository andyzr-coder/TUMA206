# Copy this file to ".env" and fill in your key (or set the variable in your shell).
# If ANTHROPIC_API_KEY is not set, the AI assistant (M5) automatically uses its
# built-in rule-based engine, so the demo still works without a key.

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Set to 1 to route tags through a real MQTT broker (requires a running broker,
# e.g. Mosquitto on localhost:1883). Default 0 = in-process bus, no broker needed.
USE_MQTT=0
